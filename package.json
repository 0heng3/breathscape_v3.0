{
  "name": "breathscape",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:all": "concurrently --kill-others-on-fail --names api,web --prefix-colors cyan,green \"node server/src/index.js\" \"vite --host 0.0.0.0\"",
    "api:dev": "node server/src/index.js",
    "build": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "quickdraw:download": "node scripts/downloadQuickDrawDataset.mjs",
    "quickdraw:download:all": "node scripts/downloadQuickDrawDataset.mjs --all",
    "quickdraw:audit": "node scripts/auditQuickDrawCoverage.mjs",
    "quickdraw:cache": "python scripts/buildQuickDrawRasterCache.py --input=quickdraw_selected --cache-dir=quickdraw_cache --size=64 --limit=3650 --workers=6",
    "quickdraw:train": "node scripts/trainQuickDrawSketchModel.mjs --input=quickdraw_selected --out=public/quickdraw-model --max-per-category=500 --epochs=18 --grid=16",
    "quickdraw:train:cnn": "python scripts/trainQuickDrawTorchCnn.py --input=quickdraw_selected --out=public/quickdraw-cnn --max-per-category=3000 --validation-per-category=650 --epochs=24 --size=64 --batch-size=96 --architecture=resnet --lr=0.00045 --target=tool --cache-dir=quickdraw_cache",
    "breathscape:assets": "node scripts/generateBreathScapeElementSvgs.mjs",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@phosphor-icons/react": "^2.1.10",
    "@vitejs/plugin-react": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "multer": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.160.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "playwright": "^1.61.0"
  }
}
